{
  "name": "lianghua-electron",
  "version": "1.0.0",
  "description": "LiangHua - 可转债券量化分析终端",
  "author": "LiangHua <dev@lianghua.app>",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -w",
    "start": "electron .",
    "dist": "npm run build:prod",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean:pycache": "node scripts/clean-pycache.js",
    "sync:dev": "node scripts/sync-backend.js --dev",
    "sync:prod": "node scripts/sync-backend.js --prod",
    "build:dev": "npm run clean:pycache && cd ../frontend && npm run build && cd ../electron && tsc && electron-builder --dir --mac -c.directories.output=release-dev && npm run sync:dev",
    "build:prod": "npm run clean:pycache && cd ../frontend && npm run build && cd ../electron && tsc && electron-builder --mac -c.directories.output=release && npm run sync:prod"
  },
  "build": {
    "appId": "com.lianghua.quant",
    "productName": "LiangHua",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/electron-updater/**",
      "node_modules/ws/**"
    ],
    "files": [
      "dist/main.js",
      "dist/preload.js",
      "dist/splash-preload.js",
      "package.json",
      "node_modules/**",
      "resources/**"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend",
        "filter": [
          "**/*",
          "!lianghua-backend",
          "!lianghua-backend.exe"
        ]
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "app/**/*.py",
          "run_app.py",
          "!.venv/**",
          "dist/lianghua-backend/**",
          "!dist/build/**",
          "!dist/**/*.pyc",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!.git/**",
          "!data/**",
          "!build/**",
          "!wheels/**",
          "!tests/**",
          "!.github/**",
          "!.pytest_cache/**",
          "!notebooks/**",
          "!performance/**",
          "!grafana/**",
          "!deploy/**",
          "!sdk/**",
          "!lianghua_backend.egg-info/**",
          "!*.pyc",
          "!.env.example",
          "!Dockerfile",
          "!docker-compose.yml",
          "!pyproject.toml",
          "requirements.txt",
          "!prometheus.yml",
          "!alembic.ini",
          "!alembic/**",
          "!lianghua-backend.spec"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}.${ext}",
      "icon": "resources/icons/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "category": "public.app-category.finance",
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "lianghua",
        "repo": "lianghua-app"
      }
    ],
    "dmg": {
      "title": "${productName} ${version}"
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "ws": "^8.18.0"
  }
}
