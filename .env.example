# Lianghua 量化系统环境配置示例
# 复制此文件为 .env 并填入实际值
# 注意：所有变量必须加 LH_ 前缀（pydantic-settings 配置要求）

# ==================== 应用配置 ====================
LH_APP_NAME=lianghua
LH_DEBUG=false
LH_LOG_LEVEL=INFO
LH_HOST=127.0.0.1
LH_PORT=8765

# ==================== 数据库配置 ====================
LH_DATABASE_URL=sqlite+aiosqlite:///./lianghua.db
# PostgreSQL示例:
# LH_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/lianghua

# ==================== Redis配置 ====================
LH_REDIS_URL=redis://localhost:6379/0

# ==================== JWT认证配置 ====================
# ⚠ 生产环境必须修改此密钥
LH_JWT_SECRET_KEY=your-super-secret-key-change-in-production
LH_JWT_ALGORITHM=HS256
LH_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== WebSocket认证 ====================
LH_WS_AUTH_TOKEN=

# ==================== AI 配置 ====================
LH_OPENAI_API_KEY=
LH_OPENAI_API_BASE=https://api.openai.com/v1
LH_ANTHROPIC_API_KEY=
LH_DEEPSEEK_API_KEY=
LH_DEEPSEEK_API_BASE=https://api.deepseek.com/v1
LH_GITHUB_TOKEN=
LH_TAVILY_API_KEY=

# ==================== 券商 API ====================
LH_EASTMONEY_API_KEY=
LH_HUATAI_API_KEY=
LH_HUATAI_API_SECRET=

# ==================== 市场数据刷新间隔 ====================
LH_MARKET_REFRESH_INTERVAL=60
LH_TRADING_REFRESH_INTERVAL=10
LH_OFF_HOURS_REFRESH_INTERVAL=60
