{
  "dashboard": {
    "title": "Lianghua SLO Dashboard",
    "tags": ["lianghua", "slo", "business"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "SLO Overview",
        "type": "stat",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "avg(sli:lianghua:availability:ratio) * 100",
            "legendFormat": "可用性"
          },
          {
            "expr": "avg(sli:lianghua:latency:ratio) * 100",
            "legendFormat": "延迟达标率"
          },
          {
            "expr": "100 - avg(sli:lianghua:error_rate:ratio) * 100",
            "legendFormat": "成功率"
          },
          {
            "expr": "slo:lianghua:error_budget:remaining",
            "legendFormat": "剩余预算"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 95, "color": "yellow"},
                {"value": 99, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "title": "Error Budget Burn Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "slo:lianghua:error_budget:burn_rate",
            "legendFormat": "Burn Rate"
          },
          {
            "expr": "14.4",
            "legendFormat": "1h Alert Threshold",
            "refId": "alert_1h"
          },
          {
            "expr": "6",
            "legendFormat": "6h Alert Threshold",
            "refId": "alert_6h"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Burn Rate"},
          {"format": "short"}
        ]
      },
      {
        "title": "SLI Trends (7d)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "sli:lianghua:availability:ratio * 100",
            "legendFormat": "可用性"
          },
          {
            "expr": "sli:lianghua:latency:ratio * 100",
            "legendFormat": "延迟达标"
          },
          {
            "expr": "sli:lianghua:trade_success:ratio * 100",
            "legendFormat": "交易成功"
          }
        ],
        "yaxes": [
          {"format": "percent", "max": 100, "min": 90},
          {"format": "short"}
        ]
      },
      {
        "title": "Business Metrics",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "lianghua_strategy_return{period=\"daily\"}",
            "legendFormat": "{{ strategy_name }}"
          },
          {
            "expr": "lianghua_max_drawdown",
            "legendFormat": "{{ strategy_name }} 回撤"
          }
        ],
        "yaxes": [
          {"format": "percentunit"},
          {"format": "short"}
        ]
      },
      {
        "title": "Signal Performance",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "rate(lianghua_signal_count_total[5m])",
            "legendFormat": "{{ signal_type }} - {{ action }}"
          },
          {
            "expr": "lianghua_signal_hit_rate{period=\"daily\"}",
            "legendFormat": "{{ signal_type }} 命中率"
          }
        ]
      },
      {
        "title": "Trade Metrics",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "rate(lianghua_trade_count_total[5m]) * 60",
            "legendFormat": "{{ trade_type }}/min"
          },
          {
            "expr": "histogram_quantile(0.95, rate(lianghua_trade_latency_seconds_bucket[5m]))",
            "legendFormat": "P95延迟"
          },
          {
            "expr": "histogram_quantile(0.99, rate(lianghua_trade_latency_seconds_bucket[5m]))",
            "legendFormat": "P99延迟"
          }
        ]
      },
      {
        "title": "Quote Latency Distribution",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "sum(rate(lianghua_quote_latency_seconds_bucket[5m])) by (le)",
            "format": "heatmap",
            "legendFormat": "{{ le }}"
          }
        ],
        "yAxis": {"format": "s"},
        "dataFormat": "tsbuckets"
      },
      {
        "title": "Position Overview",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "lianghua_position_count",
            "legendFormat": "{{ bond_type }}"
          }
        ]
      },
      {
        "title": "Risk Metrics",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 32},
        "targets": [
          {
            "expr": "lianghua_var{confidence_level=\"95\", period=\"daily\"} * 100",
            "legendFormat": "VaR(95%)"
          },
          {
            "expr": "lianghua_volatility{period=\"daily\"} * 100",
            "legendFormat": "波动率"
          },
          {
            "expr": "lianghua_beta",
            "legendFormat": "Beta"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 20,
            "min": 0,
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "title": "Attribution Analysis",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 32},
        "targets": [
          {
            "expr": "lianghua_attribution_return{attribution_type=\"allocation\"}",
            "legendFormat": "{{ factor }}"
          },
          {
            "expr": "lianghua_attribution_return{attribution_type=\"selection\"}",
            "legendFormat": "{{ factor }}"
          }
        ],
        "orientation": "horizontal"
      }
    ]
  }
}
