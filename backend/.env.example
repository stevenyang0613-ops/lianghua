# ==============================
# LiangHua 后端环境配置
# 复制为 .env 并修改各值
# 注意：所有变量必须加 LH_ 前缀（pydantic-settings 配置要求）
# ==============================

# ⚠ 生产环境必须修改此密钥
LH_JWT_SECRET_KEY=change-me-in-production

# WebSocket 认证 Token（留空则自动生成并保存到 ~/.lianghua/.ws_token）
LH_WS_AUTH_TOKEN=

# 应用配置
LH_HOST=127.0.0.1
LH_PORT=8765
LH_DEBUG=false

# 数据库
LH_DATABASE_URL=sqlite+aiosqlite:///./lianghua.db
LH_DB_PATH=data/market.db

# Redis
LH_REDIS_URL=redis://localhost:6379/0

# AI 配置
LH_OPENAI_API_KEY=
LH_OPENAI_API_BASE=https://api.openai.com/v1
LH_ANTHROPIC_API_KEY=
LH_DEEPSEEK_API_KEY=

# 日志
LH_LOG_LEVEL=INFO
