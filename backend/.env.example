# Lianghua量化系统环境配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 应用配置 ====================
APP_NAME=lianghua
APP_ENV=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///./lianghua.db
# PostgreSQL示例:
# DATABASE_URL=postgresql://user:password@localhost:5432/lianghua

# ==================== Redis配置 ====================
REDIS_URL=redis://localhost:6379/0
CELERY_REDIS_URL=redis://localhost:6379/1

# ==================== 数据源配置 ====================

# 东方财富（免费，无需认证）
EASTMONEY_ENABLED=true
EASTMONEY_TIMEOUT=30

# 巨潮资讯（免费，无需认证）
CNINFO_ENABLED=true
CNINFO_TIMEOUT=30

# Wind金融终端（需要授权）
WIND_ENABLED=false
WIND_USERNAME=
WIND_PASSWORD=
WIND_TIMEOUT=30

# 同花顺iFinD（需要授权）
THS_ENABLED=false
THS_USERNAME=
THS_PASSWORD=
THS_TIMEOUT=30

# ==================== 数据同步配置 ====================
SYNC_QUOTES_INTERVAL=60
SYNC_ANNOUNCEMENTS_INTERVAL=300
CACHE_TTL=300

# ==================== JWT认证配置 ====================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==================== Celery配置 ====================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ==================== 监控配置 ====================
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=admin123

# ==================== 邮件通知配置 ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lianghua.local

# ==================== Webhook通知配置 ====================
WEBHOOK_URL=
WEBHOOK_SECRET=

# ==================== 安全配置 ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_PER_MINUTE=60
