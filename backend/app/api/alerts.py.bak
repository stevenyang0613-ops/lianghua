from fastapi import APIRouter, HTTPException, Query
from pydantic import BaseModel
from typing import List, Optional
from datetime import datetime
from enum import Enum

router = APIRouter()

class AlertLevel(str, Enum):
    info = "info"
    warning = "warning"
    error = "error"
    critical = "critical"

class AlertStatus(str, Enum):
    firing = "firing"
    resolved = "resolved"

class AlertRule(BaseModel):
    id: str
    name: str
    level: AlertLevel
    enabled: bool
    condition: dict
    channels: List[str]
    suppressDuration: int
    createdAt: datetime
    updatedAt: datetime

class AlertEvent(BaseModel):
    id: str
    ruleId: str
    ruleName: str
    level: AlertLevel
    message: str
    status: AlertStatus
    firedAt: datetime

rules_db = {}
events_db = {}

@router.get("/rules", response_model=List[AlertRule])
async def get_rules():
    return list(rules_db.values())

@router.post("/rules", response_model=AlertRule)
async def create_rule(rule: AlertRule):
    rules_db[rule.id] = rule
    return rule

@router.delete("/rules/{rule_id}")
async def delete_rule(rule_id: str):
    if rule_id not in rules_db:
        raise HTTPException(status_code=404, detail="Rule not found")
    del rules_db[rule_id]
    return {"message": "Deleted"}

@router.get("/active", response_model=List[AlertEvent])
async def get_active_alerts():
    return [e for e in events_db.values() if e.status == AlertStatus.firing]

@router.get("/history", response_model=List[AlertEvent])
async def get_history(page: int = 1, pageSize: int = 50):
    results = list(events_db.values())
    start = (page - 1) * pageSize
    return results[start:start + pageSize]

@router.post("/{alert_id}/acknowledge")
async def acknowledge(alert_id: str):
    if alert_id not in events_db:
        raise HTTPException(status_code=404, detail="Alert not found")
    events_db[alert_id].acknowledgedAt = datetime.utcnow()
    return events_db[alert_id]

@router.post("/{alert_id}/resolve")
async def resolve(alert_id: str):
    if alert_id not in events_db:
        raise HTTPException(status_code=404, detail="Alert not found")
    events_db[alert_id].status = AlertStatus.resolved
    events_db[alert_id].resolvedAt = datetime.utcnow()
    return events_db[alert_id]
